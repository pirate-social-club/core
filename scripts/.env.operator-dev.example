# Operator-only env for dev operator workflows.
# Secrets:
# - TURSO_PLATFORM_API_TOKEN should come from Infisical: /services/control-plane
# - TURSO_COMMUNITY_DB_WRAP_KEY should come from Infisical: /services/control-plane
# - COMMUNITY_PROVISION_OPERATOR_AUTH_TOKEN should come from Infisical: /services/control-plane
# - STORY_CONTRACT_OWNER_PRIVATE_KEY stays local-only and is used for Story owner actions such as
#   configuring entitlement classes during paid-song publish
# - STORY_RUNTIME_FUNDER_PRIVATE_KEY is optional and can be a separate local wallet used only
#   for Story runtime signer top-ups. If blank, funding falls back to STORY_CONTRACT_OWNER_PRIVATE_KEY.
# - Direct Story runtime signer private keys live in Infisical /services/api, not here.
# Non-secrets:
# - TURSO_ORGANIZATION_SLUG stays outside Infisical
# - TURSO_COMMUNITY_DB_WRAP_KEY_VERSION stays outside Infisical

STORY_CONTRACT_OWNER_PRIVATE_KEY=
STORY_RUNTIME_FUNDER_PRIVATE_KEY=
CONTROL_PLANE_DATABASE_URL=postgres://user:password@ep-dev.example.neon.tech/pirate
TURSO_PLATFORM_API_TOKEN=
TURSO_ORGANIZATION_SLUG=
TURSO_COMMUNITY_DB_WRAP_KEY=
TURSO_COMMUNITY_DB_WRAP_KEY_VERSION=2
COMMUNITY_PROVISION_OPERATOR_AUTH_TOKEN=
COMMUNITY_PROVISION_OPERATOR_HOST=127.0.0.1
COMMUNITY_PROVISION_OPERATOR_PORT=8789
