{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "modal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal",
      "options": {
        "baseURL": "https://api.us-west-2.modal.direct/v1",
        "apiKey": "{env:MODAL_API_KEY}"
      },
      "models": {
        "zai-org/GLM-5-FP8": {
          "name": "GLM-5.1 via Modal"
        }
      }
    }
  },
  "model": "modal/zai-org/GLM-5-FP8",
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "title": {
      "disable": true
    },
    "summary": {
      "disable": true
    }
  }
}
