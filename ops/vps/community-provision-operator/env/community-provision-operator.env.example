# Bind only to localhost unless the host firewall and reverse proxy are explicitly configured.
COMMUNITY_PROVISION_OPERATOR_HOST=127.0.0.1
COMMUNITY_PROVISION_OPERATOR_PORT=8789
COMMUNITY_PROVISION_OPERATOR_AUTH_TOKEN=replace-with-operator-bearer-token

# Control plane and Turso platform.
CONTROL_PLANE_DATABASE_URL=postgresql://control_plane_migrator:password@example.neon.tech/neondb?sslmode=require
TURSO_PLATFORM_API_TOKEN=replace-with-turso-platform-token
TURSO_ORGANIZATION_SLUG=pirate-prod
EXPECTED_TURSO_ORGANIZATION_SLUG=pirate-prod

# Community DB credential encryption.
TURSO_COMMUNITY_DB_WRAP_KEY=replace-with-base64-or-hex-wrap-key
TURSO_COMMUNITY_DB_WRAP_KEY_VERSION=2
