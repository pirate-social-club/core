[Unit]
Description=Pirate HNS public gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pirate-hns
WorkingDirectory=/srv/pirate-hns/app
EnvironmentFile=/srv/pirate-hns/config/hns-public-gateway.env
ExecStart=/usr/bin/env bun services/gateway/hns-public/src/server.ts
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
