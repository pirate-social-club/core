app.pirate {
  reverse_proxy https://pirate.sc {
    header_up Host pirate.sc
    header_up X-Pirate-HNS-Host {host}
  }
}

api.pirate {
  reverse_proxy https://api.pirate.sc {
    header_up Host api.pirate.sc
    header_up X-Pirate-HNS-Host {host}
  }
}

*.pirate {
  @reserved host app.pirate api.pirate
  respond @reserved 404

  reverse_proxy 127.0.0.1:4049
}

*.clawitzer {
  reverse_proxy 127.0.0.1:4049
}
