HNS_VERIFIER_HOST=127.0.0.1
HNS_VERIFIER_PORT=4048
HNS_VERIFIER_AUTH_TOKEN=
# Trusted public HNS-aware recursive resolvers used for owner-managed HNS NS/TXT proof checks.
HNS_OWNER_MANAGED_RESOLVERS=82.68.70.162,82.68.70.163
HNS_OWNER_MANAGED_RESOLVER_TIMEOUT_MS=2500
PDNS_SQLITE_DATABASE=/srv/pirate-hns/authdns/data/pdns.sqlite3
PDNS_DEFAULT_SOA_CONTENT=ns1.pirate dns.pirate 0 3600 900 1209600 300
PDNS_REDISCOVER_COMMAND=docker exec pirate-hns-authdns /usr/local/bin/pdns_control rediscover
HNS_AUTHORITATIVE_NAMESERVERS=ns1.pirate.
HNS_AUTHORITATIVE_TTL=300
HNS_AUTHORITATIVE_NAMESERVER_IPV4=173.199.93.117
HNS_AUTHORITATIVE_APEX_IPV4=173.199.93.117
HNS_AUTHORITATIVE_PROFILE_IPV4=173.199.93.117
HNS_AUTHORITATIVE_WILDCARD_IPV4=173.199.93.117
