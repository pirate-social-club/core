[Unit]
Description=Pirate HNS verifier
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pirate-hns
WorkingDirectory=/srv/pirate-hns/app
EnvironmentFile=/srv/pirate-hns/config/hns-verifier.env
ExecStart=/usr/bin/env bun services/verifier/hns/src/server.ts
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
