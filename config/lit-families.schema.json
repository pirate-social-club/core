{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pirate-v2/config/lit-families.schema.json",
  "title": "Pirate V2 Lit Families",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "description", "environments"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "environments": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/environment"
      }
    }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["litApiBaseUrl", "families"],
      "properties": {
        "litApiBaseUrl": {
          "type": "string",
          "format": "uri"
        },
        "families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/family"
          }
        }
      }
    },
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "chain",
        "chainId",
        "executeGroup",
        "pkpAddress",
        "pkpPublicKey",
        "usageKeyEnvVar",
        "signerFamilyRef",
        "fundsLedgerPlaceholder",
        "actions"
      ],
      "properties": {
        "family": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "chain": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "chainId": {
          "type": "integer",
          "minimum": 1
        },
        "executeGroup": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "pkpAddress": {
          "type": "string",
          "pattern": "^(TBD|0x[a-fA-F0-9]{40})$"
        },
        "pkpPublicKey": {
          "type": "string",
          "pattern": "^(TBD|0x[a-fA-F0-9]{130})$"
        },
        "usageKeyEnvVar": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "signerFamilyRef": {
          "type": "string",
          "pattern": "^docs/signer-families\\.md#[a-z0-9-]+$"
        },
        "fundsLedgerPlaceholder": {
          "type": ["string", "null"],
          "pattern": "^[A-Z0-9_]+$"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cid", "contractMethod", "contract"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "cid": {
          "type": "string",
          "pattern": "^(TBD|ipfs://.+)$"
        },
        "contractMethod": {
          "type": "string",
          "minLength": 1
        },
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
